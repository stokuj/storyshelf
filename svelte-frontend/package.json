{
	"name": "storyshelf-svelte",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev --host 0.0.0.0 --port 5174",
		"build": "vite build",
		"preview": "vite preview --host 0.0.0.0 --port 5174",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test": "vitest run",
		"types:api": "openapi-typescript ../docs/api/openapi.yml -o ./src/lib/types/api.generated.ts"
	},
	"dependencies": {
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.0.0",
		"@xyflow/svelte": "^0.1.0",
		"bits-ui": "^1.0.0",
		"clsx": "^2.0.0",
		"lucide-svelte": "^0.400.0",
		"mode-watcher": "^1.1.0",
		"svelte": "^5.0.0",
		"svelte-sonner": "^1.1.1",
		"sveltekit-superforms": "^2.0.0",
		"tailwind-merge": "^2.0.0",
		"tailwind-variants": "^3.2.2",
		"tw-animate-css": "^1.4.0",
		"zod": "^3.0.0"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.0.0",
		"@types/node": "^22.0.0",
		"@vitest/ui": "^3.0.0",
		"csstype": "^3.2.3",
		"eslint": "^10.0.0",
		"eslint-plugin-svelte": "^3.0.0",
		"globals": "^15.0.0",
		"jsdom": "^25.0.0",
		"openapi-typescript": "^7.0.0",
		"prettier": "^3.0.0",
		"prettier-plugin-svelte": "^4.0.0",
		"svelte-check": "^4.0.0",
		"tailwindcss": "^4.0.0",
		"typescript": "^5.0.0",
		"typescript-eslint": "^8.0.0",
		"vite": "^8.0.0",
		"vitest": "^3.0.0"
	}
}
