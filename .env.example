### DATABASE
POSTGRES_DB=booksdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME

### DJANGO BACKEND
DJANGO_SECRET_KEY=CHANGE_ME
DJANGO_ENV=dev
ALLOWED_HOSTS=localhost,127.0.0.1

### JWT
JWT_ACCESS_LIFETIME_MINUTES=30
JWT_REFRESH_LIFETIME_MINUTES=1440

### CELERY
CELERY_BROKER_URL=amqp://celery:celery@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://redis:6379/0

### RABBITMQ
RABBITMQ_USER=celery
RABBITMQ_PASSWORD=celery

### NLP / LLM
NER_MODEL=en_core_web_trf
OPENROUTER_API_KEY=sk-CHANGE_ME
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=qwen/qwen3.5-35b-a3b
LLM_MAX_TOKENS=1000
NER_MIN_OCCURRENCES=5

### FRONTEND
VITE_API_PROXY_TARGET=http://django:8000

### CORS (prod only — comma-separated list of allowed origins)
CORS_ALLOWED_ORIGINS=https://example.com
