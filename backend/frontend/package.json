{
  "name": "springshelf-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:css\" \"npm run dev:serve\"",
    "dev:css": "tailwindcss -i ./assets/css/input.css -o ./assets/css/styles.css --watch",
    "dev:serve": "serve . -l 5500",
    "build:css": "tailwindcss -i ./assets/css/input.css -o ./assets/css/styles.css --minify"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "daisyui": "^5.0.9",
    "serve": "^14.2.5",
    "tailwindcss": "^3.4.17"
  }
}
