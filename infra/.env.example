# StoryShelf environment — copy to infra/.env and fill in.
# Used by docker-compose (infra/compose/*) via the Makefile (--env-file) and
# by the prod compose env_file. Dev defaults are fine as-is except secrets.

### DATABASE
POSTGRES_DB=booksdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME

### DJANGO
DJANGO_SECRET_KEY=CHANGE_ME
DJANGO_ENV=dev                      # dev | prod
ALLOWED_HOSTS=localhost,127.0.0.1

### JWT (HttpOnly cookies — see docs/decisions/ADR-001)
JWT_ACCESS_LIFETIME_MINUTES=30
JWT_REFRESH_LIFETIME_MINUTES=1440

### GOOGLE BOOKS (optional — import_books command; works without a key, lower quota)
GOOGLE_BOOKS_API_KEY=

# --- PROD ONLY (ignored in dev) ---------------------------------------------
### Caddy / TLS
DOMAIN=storyshelf.example.com       # bare domain; Caddy gets a Let's Encrypt cert
CADDY_ACME_EMAIL=admin@example.com

### CORS / CSRF (comma-separated allowlists)
CORS_ALLOWED_ORIGINS=https://storyshelf.example.com
CSRF_TRUSTED_ORIGINS=https://storyshelf.example.com

### JWT cookie hardening
JWT_COOKIE_DOMAIN=storyshelf.example.com
JWT_COOKIE_SECURE=true
JWT_COOKIE_SAMESITE=Lax

### Email (optional — defaults to console backend in dev)
# DEFAULT_FROM_EMAIL=noreply@storyshelf.example.com
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=true
