# DOMAIN: bare domain (e.g. storyshelf.example.com). Autohttps via Let's Encrypt.
# CADDY_ACME_EMAIL: contact email used for ACME registration.
# Fallback to local-dev mode when DOMAIN unset.
{
	email {$CADDY_ACME_EMAIL:admin@example.com}
}

{$DOMAIN:http://:80} {
	# Django REST API — incl. schema at /api/schema/ and Swagger UI at /api/docs/.
	# Use handle (not handle_path) so the /api prefix is preserved for Django.
	handle /api/* {
		reverse_proxy django:8000
	}

	# Django admin
	handle /admin/* {
		reverse_proxy django:8000
	}

	# SvelteKit SSR — everything else
	handle {
		reverse_proxy svelte:3000
	}

	encode gzip
	header {
		# baseline security headers — SPA is self-hosted, no third-party scripts
		Content-Security-Policy "default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy no-referrer
		Permissions-Policy "geolocation=(), microphone=(), camera=()"
	}
	log {
		output stdout
	}
}
